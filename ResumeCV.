.rev-card { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:22px 20px; position:relative; }
.rev-card::before { content:'"'; font-family:'Cormorant Garamond',serif; font-size:64px; font-weight:700; color:var(--gold); opacity:.12; position:absolute; top:10px; left:16px; line-height:1; }
