.step-num { width:48px; height:48px; border-radius:50%; border:1px solid var(--gold); display:flex; align-items:center; justify-content:center; font-family:'Cormorant Garamond',serif; font-size:22px; font-weight:700; color:var(--gold); flex-shrink:0; background:#080808; }
