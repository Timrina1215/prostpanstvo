.port-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.port-card { background:var(--card); border:1px solid var(--border); border-radius:10px; overflow:hidden; cursor:pointer; transition:border-color .2s, transform .2s; -webkit-tap-highlight-color:transparent; }
.port-card:active { transform:scale(.97); }
.port-card:hover { border-color:var(--gold); transform:translateY(-3px); }
.port-thumb { width:100%; aspect-ratio:3/4; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; }
.port-thumb.td { background:linear-gradient(160deg,#1a1f2e,#0d0e14); }
.port-thumb.tr { background:linear-gradient(160deg,#261520,#160c12); }
.port-thumb.tn { background:linear-gradient(160deg,#0c1e3a,#060d1e); }
.port-thumb.tg { background:linear-gradient(160deg,#1a3520,#0a1810); }
.port-thumb.tk { background:linear-gradient(160deg,#161616,#080808); aspect-ratio:16/9 !important; }
.mock { width:78%; border-radius:4px; overflow:hidden; box-shadow:0 8px 28px rgba(0,0,0,.7); }
.port-tap { position:absolute; bottom:12px; left:50%; transform:translateX(-50%); background:rgba(201,168,76,.2); border:1px solid rgba(201,168,76,.5); color:var(--gold); font-size:9px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:5px 12px; border-radius:20px; white-space:nowrap; backdrop-filter:blur(6px); -webkit-backdrop-filter:blur(6px); }
.port-info { padding:14px 16px; display:flex; justify-content:space-between; align-items:center; border-top:1px solid var(--border); background:var(--card); gap:8px; }
.port-name { font-size:12px; font-weight:700; color:var(--w); }
.port-style { font-size:9px; color:var(--dim); margin-top:2px; }
.port-badge { font-size:8px; font-weight:800; letter-spacing:1px; color:#080808; background:var(--gold); padding:3px 9px; border-radius:20px; flex-shrink:0; }

