<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; background: #080808; }
body { font-family: 'Outfit', sans-serif; background: #080808; color: #f5f2ee; overflow-x: hidden; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

:root {
  --gold: #c9a84c;
  --gold2: #f0d080;
  --w: #f5f2ee;
  --m: #b0aca8;
  --dim: #666260;
  --card: #161616;
  --border: #262626;
