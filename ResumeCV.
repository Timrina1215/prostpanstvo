/* PRICING */
.price-list { display:grid; grid-template-columns:1fr; gap:16px; }
.price-card { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:28px 22px; position:relative; transition:border-color .2s, transform .2s; }
