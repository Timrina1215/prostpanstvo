.sec-wrap.alt { background:#0e0e0e; }
.sec-inner { max-width:1200px; margin:0 auto; }
.sec-tag { display:inline-flex; align-items:center; gap:8px; font-size:9px; font-weight:800; letter-spacing:3.5px; text-transform:uppercase; color:var(--gold); margin-bottom:10px; }
